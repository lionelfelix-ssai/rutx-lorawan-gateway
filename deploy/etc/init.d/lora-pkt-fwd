#!/bin/sh /etc/rc.common

START=90
STOP=10
USE_PROCD=1

start_service() {
    local i=0
    while [ ! -e /dev/ttyACM0 ] && [ $i -lt 30 ]; do
        sleep 1
        i=$((i + 1))
    done
    if [ ! -e /dev/ttyACM0 ]; then
        logger -t lora-pkt-fwd "ERROR: /dev/ttyACM0 not found after 30s"
        return 1
    fi

    procd_open_instance
    procd_set_param command /usr/local/lora/bin/start_pkt_fwd.sh
    procd_set_param respawn 60 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile /var/run/lora_pkt_fwd.pid
    procd_close_instance
}

stop_service() {
    logger -t lora-pkt-fwd "Stopping"
}
